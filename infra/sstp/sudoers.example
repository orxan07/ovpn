# Drop-in для /etc/sudoers.d/wg-admin-sstp (chmod 440)
#
# Даёт пользователю, под которым работает Node-сервер админки (по умолчанию root,
# но если ты переехал на отдельный sysuser — поменяй имя), право выполнять
# нужные для управления SSTP команды без пароля.
#
# Если админка крутится от root (сейчас — да), этот файл не нужен.
# Если переедешь на отдельный пользователь, например `wgadmin`:
#
#   sudo install -m 440 sudoers.example /etc/sudoers.d/wg-admin-sstp
#   sudo visudo -c    # проверить синтаксис
#
# и заменить ниже `wgadmin` на реальное имя.

wgadmin ALL=(root) NOPASSWD: /usr/sbin/accel-cmd *
wgadmin ALL=(root) NOPASSWD: /bin/cat /etc/accel-ppp/chap-secrets
wgadmin ALL=(root) NOPASSWD: /usr/bin/install -m 600 /tmp/sstp-secrets-* /etc/accel-ppp/chap-secrets
wgadmin ALL=(root) NOPASSWD: /bin/systemctl restart accel-ppp
wgadmin ALL=(root) NOPASSWD: /bin/systemctl is-active accel-ppp
wgadmin ALL=(root) NOPASSWD: /bin/systemctl show accel-ppp *
wgadmin ALL=(root) NOPASSWD: /bin/cat /etc/accel-ppp.conf
wgadmin ALL=(root) NOPASSWD: /usr/bin/env bash /opt/wg-admin/infra/sstp/firewall.sh
wgadmin ALL=(root) NOPASSWD: /usr/bin/iptables *
wgadmin ALL=(root) NOPASSWD: /usr/bin/install -m 644 /tmp/sstp-firewall-*.service /etc/systemd/system/sstp-firewall.service
wgadmin ALL=(root) NOPASSWD: /bin/systemctl daemon-reload
wgadmin ALL=(root) NOPASSWD: /bin/systemctl enable --now sstp-firewall
wgadmin ALL=(root) NOPASSWD: /bin/systemctl disable --now sstp-firewall
wgadmin ALL=(root) NOPASSWD: /bin/systemctl is-active sstp-firewall
wgadmin ALL=(root) NOPASSWD: /bin/systemctl is-enabled sstp-firewall
wgadmin ALL=(root) NOPASSWD: /usr/bin/test -f /etc/systemd/system/sstp-firewall.service
wgadmin ALL=(root) NOPASSWD: /bin/rm -f /etc/systemd/system/sstp-firewall.service
